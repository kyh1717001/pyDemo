# Jetson部署脚本配置文件
# 使用方法: source jetson_config.env 或 export $(cat jetson_config.env | xargs)

# SSH连接配置
SSH_USER=nvidia          # SSH用户名（Jetson默认用户）
SSH_PORT=22             # SSH端口
SSH_KEY=                # SSH私钥路径（可选，留空使用密码认证）

# 网络配置
DEFAULT_GATEWAY=        # 默认网关（留空自动检测）
DNS_SERVERS=8.8.8.8     # DNS服务器

# 目录配置
PROJECT_DIR=$HOME/projects      # Git项目存放目录
DOWNLOAD_DIR=$HOME/downloads    # 下载文件存放目录

# 超时设置
SSH_TIMEOUT=10          # SSH连接超时时间（秒）
DOWNLOAD_TIMEOUT=300    # 下载超时时间（秒）

# 日志设置
LOG_LEVEL=INFO          # 日志级别: DEBUG, INFO, WARNING, ERROR
ENABLE_COLOR=true       # 是否启用彩色输出